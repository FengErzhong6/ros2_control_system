<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="marvin_dual">

  <!--
    Dual-arm composite URDF (xacro).
    - Includes both left and right arm models from `asset_description`.
    - Adds a common `world` link and fixed joints to each arm base.
    - Adds two ros2_control hardware components (left + right) via macros.

    Args:
      left_xyz, left_rpy:  mount pose of Base_L w.r.t world
      right_xyz, right_rpy: mount pose of Base_R w.r.t world
  -->

  <xacro:arg name="left_xyz" default="0 0.037 0.3618964" />
  <xacro:arg name="left_rpy" default="-1.5707963 0 0" />
  <xacro:arg name="right_xyz" default="0 -0.037 0.3618964" />
  <xacro:arg name="right_rpy" default="1.5707963 0 0" />
  <xacro:arg name="use_gripper_L" default="true" />
  <xacro:arg name="use_gripper_R" default="true" />
  <xacro:arg name="use_mock_hardware" default="false" />

  <link name="world" />

  <!-- Arm models -->
  <xacro:include filename="$(find asset_description)/marvin/urdf/Marvin M6-S-L-CCS-696-V4.0 urdf.urdf" />
  <xacro:include filename="$(find asset_description)/marvin/urdf/Marvin M6-S-R-CCS-696-V4.0 urdf.urdf" />

  <!-- Mount them under world -->
  <joint name="world_to_base_l" type="fixed">
    <origin xyz="$(arg left_xyz)" rpy="$(arg left_rpy)" />
    <parent link="world" />
    <child link="Base_L" />
  </joint>

  <joint name="world_to_base_r" type="fixed">
    <origin xyz="$(arg right_xyz)" rpy="$(arg right_rpy)" />
    <parent link="world" />
    <child link="Base_R" />
  </joint>

  <!-- ros2_control description (single hardware component for both arms) -->
  <xacro:include filename="$(find marvin_system)/description/ros2_control/marvin_dual_system.ros2_control.xacro" />

  <!--
    Parallel-jaw gripper at the end-effector tip.

    Coordinate frames (from mesh bbox + DH flange params):
      Link7 -> EE:  xyz="0 -0.095 0"  rpy="1.5708 -1.5708 0"
      In EE frame:  Z_ee = forward (-Y_link7),  Y_ee = opening (-X_link7)

    gripper_L/R:  virtual revolute 0~1 (control interface).
    Fingers:      prismatic mimic along ±Y_ee.
                  Length 15 cm (Z_ee), max opening 8 cm (±4 cm Y_ee).
  -->
  <xacro:if value="$(arg use_gripper_L)">
    <link name="ee_L"/>
    <joint name="ee_joint_L" type="fixed">
      <origin xyz="0 -0.095 0" rpy="1.5708 -1.5708 0"/>
      <parent link="Link7_L"/>
      <child link="ee_L"/>
    </joint>

    <link name="gripper_L_link"/>
    <joint name="gripper_L" type="revolute">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="ee_L"/>
      <child link="gripper_L_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="0.0" upper="1.0" effort="0" velocity="1.0"/>
    </joint>

    <link name="left_finger_L_link">
      <visual>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry><box size="0.02 0.01 0.15"/></geometry>
        <material name="gripper_gray"><color rgba="0.4 0.4 0.4 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry><box size="0.02 0.01 0.15"/></geometry>
      </collision>
      <inertial><mass value="0.05"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
    </link>
    <joint name="left_finger_L" type="prismatic">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="ee_L"/>
      <child link="left_finger_L_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.04" upper="0" effort="0" velocity="0.5"/>
      <mimic joint="gripper_L" multiplier="-0.035" offset="0"/>
    </joint>

    <link name="right_finger_L_link">
      <visual>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry><box size="0.02 0.01 0.15"/></geometry>
        <material name="gripper_gray"><color rgba="0.4 0.4 0.4 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry><box size="0.02 0.01 0.15"/></geometry>
      </collision>
      <inertial><mass value="0.05"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
    </link>
    <joint name="right_finger_L" type="prismatic">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="ee_L"/>
      <child link="right_finger_L_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="0" upper="0.04" effort="0" velocity="0.5"/>
      <mimic joint="gripper_L" multiplier="0.035" offset="0"/>
    </joint>
  </xacro:if>

  <xacro:if value="$(arg use_gripper_R)">
    <link name="ee_R"/>
    <joint name="ee_joint_R" type="fixed">
      <origin xyz="0 -0.095 0" rpy="1.5708 -1.5708 0"/>
      <parent link="Link7_R"/>
      <child link="ee_R"/>
    </joint>

    <link name="gripper_R_link"/>
    <joint name="gripper_R" type="revolute">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="ee_R"/>
      <child link="gripper_R_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="0.0" upper="1.0" effort="0" velocity="1.0"/>
    </joint>

    <link name="left_finger_R_link">
      <visual>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry><box size="0.02 0.01 0.15"/></geometry>
        <material name="gripper_gray"><color rgba="0.4 0.4 0.4 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry><box size="0.02 0.01 0.15"/></geometry>
      </collision>
      <inertial><mass value="0.05"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
    </link>
    <joint name="left_finger_R" type="prismatic">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="ee_R"/>
      <child link="left_finger_R_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.04" upper="0" effort="0" velocity="0.5"/>
      <mimic joint="gripper_R" multiplier="-0.035" offset="0"/>
    </joint>

    <link name="right_finger_R_link">
      <visual>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry><box size="0.02 0.01 0.15"/></geometry>
        <material name="gripper_gray"><color rgba="0.4 0.4 0.4 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
        <geometry><box size="0.02 0.01 0.15"/></geometry>
      </collision>
      <inertial><mass value="0.05"/><inertia ixx="1e-5" ixy="0" ixz="0" iyy="1e-5" iyz="0" izz="1e-5"/></inertial>
    </link>
    <joint name="right_finger_R" type="prismatic">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="ee_R"/>
      <child link="right_finger_R_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="0" upper="0.04" effort="0" velocity="0.5"/>
      <mimic joint="gripper_R" multiplier="0.035" offset="0"/>
    </joint>
  </xacro:if>

  <xacro:marvin_dual_ros2_control name="marvin_dual"
    use_mock_hardware="$(arg use_mock_hardware)"
    use_gripper_L="$(arg use_gripper_L)"
    use_gripper_R="$(arg use_gripper_R)" />

</robot>
