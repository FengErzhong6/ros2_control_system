<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="marvin_dual_ros2_control"
               params="name
                       use_gripper_L:=false  gripper_L_arm:=A  gripper_L_can_id:=1
                       use_gripper_R:=false  gripper_R_arm:=B  gripper_R_can_id:=2">

    <ros2_control name="${name}" type="system">
      <hardware>
        <plugin>ros2_control_marvin/MarvinHardware</plugin>
        <param name="ip">192.168.1.190</param>
        <param name="joint_vel_ratio">80</param>
        <param name="joint_acc_ratio">80</param>
        <param name="connect_timeout_ms">1500</param>
        <param name="state_timeout_ms">5000</param>
        <param name="no_frame_timeout_ms">800</param>
        <param name="sdk_log_enabled">0</param>
        <param name="home_position_L">1.16 -1.28 -1.5707963 -1.25 0 0 0</param>
        <param name="home_position_R">-1.16 -1.28 1.5707963 -1.25 0 0 0</param>

        <!-- Workspace z-floor safety check (optional, remove to disable) -->
        <param name="workspace_z_min">0.0</param>
        <param name="workspace_safety_margin">0.06</param>
        <param name="mount_xyz_L">$(arg left_xyz)</param>
        <param name="mount_rpy_L">$(arg left_rpy)</param>
        <param name="mount_xyz_R">$(arg right_xyz)</param>
        <param name="mount_rpy_R">$(arg right_rpy)</param>
        <xacro:if value="${str(use_gripper_L).lower() == 'true' or str(use_gripper_R).lower() == 'true'}">
          <!-- Gripper tip in Link7 frame: flange 9.5cm + finger 15cm = 24.5cm along -Y_link7 -->
          <param name="tool_offset">0 -0.245 0</param>
        </xacro:if>
      </hardware>

      <!-- Left arm (SDK arm A, index 0) — joints 0..6 -->
      <joint name="Joint1_L">
        <command_interface name="position">
          <param name="min">-3.1067</param>
          <param name="max">3.1067</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="Joint2_L">
        <command_interface name="position">
          <param name="min">-2.0944</param>
          <param name="max">2.0944</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="Joint3_L">
        <command_interface name="position">
          <param name="min">-3.1067</param>
          <param name="max">3.1067</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="Joint4_L">
        <command_interface name="position">
          <param name="min">-2.5307</param>
          <param name="max">1.0472</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="Joint5_L">
        <command_interface name="position">
          <param name="min">-3.1067</param>
          <param name="max">3.1067</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="Joint6_L">
        <command_interface name="position">
          <param name="min">-1.0472</param>
          <param name="max">1.0472</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="Joint7_L">
        <command_interface name="position">
          <param name="min">-1.5708</param>
          <param name="max">1.5708</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <!-- Right arm (SDK arm B, index 1) — joints 7..13 -->
      <joint name="Joint1_R">
        <command_interface name="position">
          <param name="min">-3.1067</param>
          <param name="max">3.1067</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="Joint2_R">
        <command_interface name="position">
          <param name="min">-2.0944</param>
          <param name="max">2.0944</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="Joint3_R">
        <command_interface name="position">
          <param name="min">-3.1067</param>
          <param name="max">3.1067</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="Joint4_R">
        <command_interface name="position">
          <param name="min">-2.5307</param>
          <param name="max">1.0472</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="Joint5_R">
        <command_interface name="position">
          <param name="min">-3.1067</param>
          <param name="max">3.1067</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="Joint6_R">
        <command_interface name="position">
          <param name="min">-1.0472</param>
          <param name="max">1.0472</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
      <joint name="Joint7_R">
        <command_interface name="position">
          <param name="min">-1.5708</param>
          <param name="max">1.5708</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <!-- Optional: OmniPicker gripper on left arm -->
      <xacro:if value="${str(use_gripper_L).lower() == 'true'}">
        <joint name="gripper_L">
          <param name="type">omnipicker</param>
          <param name="arm_side">${gripper_L_arm}</param>
          <param name="can_node_id">${gripper_L_can_id}</param>
          <command_interface name="position">
            <param name="min">0.0</param>
            <param name="max">1.0</param>
          </command_interface>
          <state_interface name="position"/>
        </joint>
      </xacro:if>

      <!-- Optional: OmniPicker gripper on right arm -->
      <xacro:if value="${str(use_gripper_R).lower() == 'true'}">
        <joint name="gripper_R">
          <param name="type">omnipicker</param>
          <param name="arm_side">${gripper_R_arm}</param>
          <param name="can_node_id">${gripper_R_can_id}</param>
          <command_interface name="position">
            <param name="min">0.0</param>
            <param name="max">1.0</param>
          </command_interface>
          <state_interface name="position"/>
        </joint>
      </xacro:if>

    </ros2_control>

  </xacro:macro>

</robot>
